generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model SalaConfig {
  id                 String   @id @default(cuid())
  salaId             String   @unique
  mensagemBoasVindas String   @default("BEM-VINDO!")
  logoCliente        String?
  nomeCliente        String?
  mostrarInfoEvento  Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}
