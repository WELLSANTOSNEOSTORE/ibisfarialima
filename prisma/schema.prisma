generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model LogoLibrary {
  id        Int      @id @default(autoincrement())
  nome      String
  url       String
  createdAt DateTime @default(now())
}

model SalaConfig {
  id                 String   @id @default(cuid())
  salaId             String   @unique
  mensagemBoasVindas String   @default("BEM-VINDO!")
  logoCliente        String?
  nomeCliente        String?
  mostrarInfoEvento  Boolean  @default(true)
  videoUrl           String?
  mostrarVideo       Boolean  @default(false)
  orientacao         String   @default("landscape")
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}
